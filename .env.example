# Copy this file to .env and fill in values before running `make up`.
# .env is listed in .gitignore — never commit real secrets.

# ---- PostgreSQL ----
POSTGRES_PASSWORD=cloudbackup_dev
POSTGRES_PORT=5432

# ---- Backend ----
BACKEND_PORT=8080

# JWT signing secret — change to a long random string in any real deployment.
# Generate one with: openssl rand -hex 32
JWT_SECRET=changeme_use_a_long_random_secret

# ---- MinIO object storage ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev
MINIO_BUCKET=cloudbackup
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# MINIO_ENDPOINT is used by the backend container to reach MinIO (host:port, no scheme).
# When running via docker compose this is minio:9000.
# When running the backend locally against a docker-compose MinIO, use localhost:9000.
MINIO_ENDPOINT=minio:9000
MINIO_USE_SSL=false

# ---- Testing ----
# Set this to run integration tests against a real database.
# Example: postgres://cloudbackup:cloudbackup_dev@localhost:5432/cloudbackup?sslmode=disable
TEST_DATABASE_URL=
